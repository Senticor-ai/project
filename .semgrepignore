# ── Semgrep path exclusions ─────────────────────────────────────────
# Documented threat model: these paths contain non-production code
# that triggers false positives in security scanning.
#
# See: https://github.com/Senticor-ai/project/security/code-scanning

# HTML fixtures — scraped snapshots of German government websites
# (FIM Portal, Bundesagentur, etc.) used as test context data.
# Alerts: missing-integrity, plaintext-http-link, detected-jwt-token
# Threat model: static test data, never served to browsers or parsed
# as trusted HTML. Links and integrity attributes are irrelevant.
fixtures/

# Generated coverage reports from Vitest/Istanbul.
# Already in .gitignore; only appears if tests ran locally.
# Alerts: insecure-document-method, detect-non-literal-regexp
# Threat model: auto-generated tooling output, not project code.
frontend/coverage/

# Playwright E2E page objects and test helpers.
# Alerts: detect-non-literal-regexp (ReDoS)
# Threat model: test infrastructure only, never runs in production.
# Dynamic RegExp inputs are pre-escaped via escapeRegex() helper.
frontend/e2e/

# Backend test files — use hardcoded test credentials, raw SQL assertions,
# and dynamic URLs intentionally. Not production code.
# Alerts: jwt-hardcoded-secret, hardcoded-password-default-argument,
#         dynamic-urllib-use-detected, sqlalchemy-execute-raw-query
backend/tests/

# Kustomize strategic merge patches — these are partial YAML overlays
# that inherit securityContext (runAsNonRoot, etc.) from base manifests.
# Semgrep doesn't understand Kustomize patching and flags them as missing
# security contexts.
# Alerts: run-as-non-root, allow-privilege-escalation-no-securitycontext
infra/k8s/overlays/

# Third-party dependencies
node_modules/

# Build artifacts
frontend/dist/
